<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="ISDrupal">
  <description>Customized Code Sniffer rules for Interactive Strategies Drupal projects.</description>

  <arg name="extensions" value="inc,install,module,php,profile,test,theme,yml"/>

  <exclude-pattern>*/vendor/*</exclude-pattern>

  <rule ref="vendor/drupal/coder/coder_sniffer/Drupal">
    <exclude name="Drupal.Commenting.Deprecated.IncorrectTextLayout"/>
    <exclude name="Drupal.Commenting.Deprecated.DeprecatedMissingSeeTag"/>
    <exclude name="Drupal.Commenting.FunctionComment.SeeAdditionalText"/>
    <exclude name="Drupal.Commenting.InlineComment.InvalidEndChar"/>
    <exclude name="Drupal.Commenting.InlineComment.NotCapital"/>
    <exclude name="Drupal.Commenting.InlineComment.SpacingAfter"/>
    <exclude name="Drupal.Commenting.TodoComment.TodoFormat"/>
    <exclude name="Drupal.ControlStructures.ControlSignature.NewlineAfterCloseBrace"/>
    <exclude name="Drupal.ControlStructures.ControlSignature.NewlineAfterOpenBrace"/>
    <exclude name="Drupal.InfoFiles.AutoAddedKeys"/>
    <exclude name="Drupal.Semantics.FunctionTriggerError.TriggerErrorTextLayoutRelaxed"/>
    <exclude name="Drupal.WhiteSpace.CloseBracketSpacing.ClosingWhitespace"/>
    <exclude name="Drupal.WhiteSpace.OpenBracketSpacing.OpeningWhitespace"/>
    <exclude name="Drupal.WhiteSpace.ScopeClosingBrace.Line"/>
    <exclude name="DrupalPractice.Commenting.CommentEmptyLine"/>
    <exclude name="PEAR.Functions.FunctionCallSignature.SpaceAfterCloseBracket"/>
    <exclude name="Squiz.WhiteSpace.SemicolonSpacing.Incorrect"/>
    <exclude name="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore"/>
  </rule>

  <rule ref="vendor/drupal/coder/coder_sniffer/DrupalPractice">
    <exclude name="DrupalPractice.InfoFiles.NamespacedDependency.NonNamespaced"/>
  </rule>

  <rule ref="Drupal.Arrays.Array">
    <properties>
      <property name="lineLimit" value="120" />
    </properties>
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Arrays.DisallowLongArraySyntax">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.ClassDeclaration.BraceOnNewLine">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.ClassDeclaration.CloseBraceAfterBody">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.ClassDeclaration.CloseBraceSameLine">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.ClassDeclaration.SpaceBeforeBrace">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.FullyQualifiedNamespace">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.PropertyDeclaration.Multiple">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Classes.UseGlobalClass.RedundantUseStatement">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.ClassComment.Missing">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.LongFullStop">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.LongNotCapital">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.MissingShort">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.ParamGroup">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.ParamNotFirst">
    <type>warning</type>
    <exclude-pattern>*/Commands/*</exclude-pattern>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.ShortFullStop">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.ShortNotCapital">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.ShortSingleLine">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.SpacingAfter">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.SpacingBeforeShort">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.SpacingBeforeTags">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.TagGroupSpacing">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocComment.TagValueIndent">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocCommentAlignment.NoSpaceAfterStar">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.DocCommentLongArraySyntax.DocLongArray">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FileComment.Missing">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FileComment.SpacingAfterComment">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.Missing">
    <type>warning</type>
    <exclude-pattern>*/Commands/*</exclude-pattern>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.MissingParamComment">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.MissingReturnComment">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.ParamCommentFullStop">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.ParamCommentIndentation">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.ParamCommentNewLine">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.ParamCommentNotCapital">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.FunctionComment.ParamMissingDefinition">
    <exclude-pattern>*/Commands/*</exclude-pattern>
  </rule>

  <rule ref="Drupal.Commenting.InlineComment">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.PostStatementComment">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Commenting.VariableComment.Missing">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.ControlStructures.ControlSignature.SpaceAfterCloseParenthesis">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.ControlStructures.ControlSignature.SpaceAfterKeyword">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.NamingConventions.ValidFunctionName">
    <properties>
      <property name="strict" value="false"/>
    </properties>
  </rule>

  <rule ref="Drupal.NamingConventions.ValidFunctionName.InvalidPrefix">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.NamingConventions.ValidFunctionName.NotCamelCaps">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.NamingConventions.ValidFunctionName.ScopeNotCamelCaps">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Files.EndFileNewline">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Files.LineLength">
    <properties>
      <property name="lineLimit" value="120" />
    </properties>
  </rule>

  <rule ref="Drupal.Formatting">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.Functions.DiscouragedFunctions">
    <type>error</type>
  </rule>

  <rule ref="Drupal.Strings.UnnecessaryStringConcat">
    <type>warning</type>
  </rule>

  <rule ref="Drupal.WhiteSpace">
    <type>warning</type>
  </rule>

  <rule ref="Generic.CodeAnalysis.ForLoopShouldBeWhileLoop"/>

  <rule ref="Generic.CodeAnalysis.JumbledIncrementer"/>

  <rule ref="Generic.CodeAnalysis.UnconditionalIfStatement"/>

  <rule ref="Generic.Formatting.SpaceAfterCast.NoSpace">
    <type>warning</type>
  </rule>

  <rule ref="Generic.Functions.FunctionCallArgumentSpacing.SpaceBeforeComma">
    <type>warning</type>
  </rule>

  <rule ref="Generic.Functions.FunctionCallArgumentSpacing.TooMuchSpaceAfterComma">
    <type>warning</type>
  </rule>

  <rule ref="Generic.Functions.OpeningFunctionBraceKernighanRitchie">
    <type>warning</type>
  </rule>

  <rule ref="Generic.Metrics.NestingLevel">
    <properties>
      <property name="absoluteNestingLevel" value="99" />
      <property name="nestingLevel" value="8" />
    </properties>
  </rule>

  <rule ref="Generic.PHP.CharacterBeforePHPOpeningTag"/>

  <rule ref="Generic.PHP.DiscourageGoto">
    <type>error</type>
  </rule>

  <rule ref="Generic.PHP.ForbiddenFunctions">
    <properties>
      <property name="forbiddenFunctions" type="array">
        <element key="eval" value="null"/>
        <element key="extract" value="list"/>
        <element key="mail" value="\Drupal::service('plugin.manager.mail')->mail"/>
        <element key="ob_end_flush" value="ob_get_clean"/>
        <element key="ob_flush" value="null"/>
        <element key="ob_get_flush" value="ob_get_clean"/>
        <element key="phpinfo" value="null"/>
      </property>
    </properties>
  </rule>

  <rule ref="Generic.PHP.NoSilencedErrors"/>

  <rule ref="Generic.PHP.UpperCaseConstant">
    <type>warning</type>
  </rule>

  <rule ref="Generic.WhiteSpace.DisallowTabIndent.TabsUsed">
     <type>warning</type>
  </rule>

  <rule ref="ISDrupal.Namespaces.CompilerFriendlyGlobalFunctions"/>

  <rule ref="PEAR.Functions.FunctionCallSignature">
    <properties>
      <property name="indent" value="2" />
    </properties>
  </rule>

  <rule ref="PEAR.Functions.FunctionCallSignature.Indent">
    <severity>5</severity>
    <type>warning</type>
  </rule>

  <rule ref="PEAR.Functions.FunctionCallSignature.SpaceAfterOpenBracket">
    <severity>5</severity>
    <type>warning</type>
  </rule>

  <rule ref="PEAR.Functions.FunctionCallSignature.SpaceBeforeCloseBracket">
    <severity>5</severity>
    <type>warning</type>
  </rule>

  <rule ref="PSR2.Namespaces.NamespaceDeclaration.BlankLineAfter">
    <type>warning</type>
  </rule>

  <rule ref="PSR2.Namespaces.UseDeclaration.SpaceAfterLastUse">
    <type>warning</type>
  </rule>

  <rule ref="PSR12.ControlStructures.BooleanOperatorPlacement">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Arrays.DisallowImplicitArrayCreation">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Classes.ClassConstantVisibility">
    <properties>
      <property name="fixable" value="true" />
    </properties>
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Classes.UselessLateStaticBinding">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.ControlStructures.DisallowContinueWithoutIntegerOperandInSwitch"/>

  <rule ref="SlevomatCodingStandard.ControlStructures.RequireNullCoalesceEqualOperator">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.ControlStructures.RequireNullCoalesceOperator">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.ControlStructures.RequireShortTernaryOperator">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.ControlStructures.UselessIfConditionWithReturn">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.ControlStructures.UselessTernaryOperator">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Exceptions.DeadCatch">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Exceptions.RequireNonCapturingCatch">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Functions.RequireTrailingCommaInDeclaration">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Namespaces.AlphabeticallySortedUses">
    <properties>
      <property name="caseSensitive" value="true" />
    </properties>
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.Namespaces.UselessAlias">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.PHP.OptimizedFunctionsWithoutUnpacking">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.PHP.ShortList">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.TypeHints.NullTypeHintOnLastPosition">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.TypeHints.NullableTypeForNullDefaultValue">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.TypeHints.ParameterTypeHintSpacing">
    <type>warning</type>
  </rule>

  <rule ref="SlevomatCodingStandard.TypeHints.ReturnTypeHintSpacing">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Arrays.ArrayDeclaration.CloseBraceNewLine">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Arrays.ArrayDeclaration.CommaAfterLast">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Arrays.ArrayDeclaration.IndexNoNewline">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Arrays.ArrayDeclaration.NoSpaceAfterComma">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Arrays.ArrayDeclaration.SpaceInEmptyArray">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.ControlStructures.ForLoopDeclaration">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.ControlStructures.SwitchDeclaration.MissingCase">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.ControlStructures.SwitchDeclaration.SpacingAfterBreak">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.ControlStructures.SwitchDeclaration.SpaceBeforeColonCase">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Functions.FunctionDeclarationArgumentSpacing">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Functions.MultiLineFunctionDeclaration">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Operators.ValidLogicalOperators">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.PHP.DisallowSizeFunctionsInLoops">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.PHP.DiscouragedFunctions"/>

  <rule ref="Squiz.PHP.InnerFunctions">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Scope.StaticThisUsage"/>

  <rule ref="Squiz.Strings.ConcatenationSpacing">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.Strings.DoubleQuoteUsage.NotRequired">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.WhiteSpace.FunctionSpacing">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.WhiteSpace.OperatorSpacing">
    <type>warning</type>
  </rule>

  <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace">
    <type>warning</type>
  </rule>
</ruleset>
